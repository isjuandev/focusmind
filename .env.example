# ─────────────────────────────────────────────────────────────
# Vercel KV (Redis) — se auto-inyectan al conectar Vercel KV
# desde el dashboard: Storage → KV → Connect to Project
# ─────────────────────────────────────────────────────────────
KV_REST_API_URL=https://xxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# (Opcional) Protege /metrics con un token secreto
# Si no lo defines, el dashboard es público
# ─────────────────────────────────────────────────────────────
METRICS_SECRET=una_clave_secreta_aqui
